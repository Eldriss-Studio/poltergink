{
  "name": "poltergink",
  "version": "0.0.0",
  "description": "LLM-native TypeScript wrapper around inkjs — a poltergeist in the Ink shell. An LLM holds a persona, reads the narrative, and is forced to pick from author-defined choices.",
  "keywords": [
    "ink",
    "inkjs",
    "inkle",
    "narrative",
    "interactive-fiction",
    "llm",
    "ai",
    "agent",
    "persona",
    "typescript"
  ],
  "homepage": "https://github.com/Eldriss-Studio/poltergink#readme",
  "bugs": {
    "url": "https://github.com/Eldriss-Studio/poltergink/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eldriss-Studio/poltergink.git"
  },
  "license": "MIT",
  "author": "Yuri Flagrare <yuri.flagrare@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:tsdoc": "eslint \"src/**/*.ts\"",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:atdd": "NODE_OPTIONS='--import tsx/esm --no-warnings' cucumber-js --parallel 4",
    "knip": "knip",
    "publint": "publint",
    "attw": "attw --pack --profile node16",
    "docs:api": "typedoc",
    "verify": "pnpm typecheck && pnpm lint && pnpm lint:tsdoc && pnpm knip && pnpm test:coverage && pnpm test:atdd && pnpm build && pnpm publint",
    "verify:publish": "pnpm verify && pnpm attw",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "ai": "^6.0.184",
    "inkjs": "^2.4.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "ollama-ai-provider-v2": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "ollama-ai-provider-v2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@cucumber/cucumber": "^12.9.0",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
